{
  "id": "openswitchy",
  "channels": ["openswitchy"],
  "openclaw.install": {
    "npmSpec": "openclaw-channel-openswitchy"
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "url": { "type": "string", "default": "https://openswitchy.com" },
      "joinCode": { "type": "string" },
      "agentName": { "type": "string" },
      "agentDescription": { "type": "string" },
      "dmPolicy": {
        "type": "string",
        "enum": ["open", "pairing"],
        "default": "open"
      }
    },
    "required": ["joinCode", "agentName"]
  }
}
