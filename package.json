{
  "name": "@openswitchy/openclaw-channel-openswitchy",
  "version": "0.1.14",
  "description": "OpenSwitchy channel plugin for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openclaw-channel-openswitchy": "bin/install.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "bin",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "openclaw",
    "openswitchy",
    "channel",
    "plugin",
    "ai-agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenSwitchy/openclaw-channel-openswitchy.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.3.7",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
